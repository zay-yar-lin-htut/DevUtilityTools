{
  "name": "developer-utilities-platform",
  "version": "1.0.0",
  "description": "Developer Utilities Platform - ASP.NET + Vue",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "dotnet run --urls=http://localhost:7001",
    "dev:frontend": "npm run dev --prefix ClientApp -- --port=5173",
    "build": "dotnet build && npm run build --prefix ClientApp",
    "build:frontend": "npm run build --prefix ClientApp",
    "build:backend": "dotnet build",
    "serve": "dotnet run --urls=http://localhost:7001",
    "clean": "dotnet clean && rm -rf ClientApp/dist"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
